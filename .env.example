# ──────────────────────────────────────────
#  KrishiSeva — Environment Variables
#  Copy this file to .env and fill values
# ──────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=7d

# Anthropic API (for KrishiBot AI chatbot)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Database path (SQLite file)
DB_PATH=./db/krishiseva.db

# Optional: OpenWeatherMap (live weather)
# WEATHER_API_KEY=your_openweather_key
# WEATHER_CITY=Pune
# WEATHER_COUNTRY=IN
